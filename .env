# Application
NODE_ENV=production
PORT=3000

# Database (cPanel MongoDB or external MongoDB Atlas)
MONGODB_URI=mongodb://username:password@localhost:27017/gismac_db
# OR for MongoDB Atlas:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/gismac_db

# Security
JWT_SECRET=your-super-secret-jwt-key-min-32-characters-long
